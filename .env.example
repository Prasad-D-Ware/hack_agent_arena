# Copy to .env and fill in one LLM provider key.
LLM_PROVIDER=openrouter

# OpenRouter (default)
OPENROUTER_API_KEY=

# Groq (fast OpenAI-compatible fallback/provider)
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# MODEL=llama-3.3-70b-versatile

# Optional overrides:
# MODEL=anthropic/claude-opus-4        # any OpenRouter "provider/model" slug
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # or a local OpenAI-compatible host
# APPWORLD_EXPERIMENT=team_yourname
# APPWORLD_DATASET=dev
# MAX_TASKS=0
# MAX_INTERACTIONS=30

# 🐉 HydraDB context layer (bonus). Off by default.
#   1) ingest docs once (offline):  HYDRA_DB_API_KEY=... python bootstrap_docs.py
#   2) enable for the run:          USE_HYDRA=1
# USE_HYDRA=1
# HYDRA_DB_API_KEY=                    # from https://app.hydradb.com (bootstrap needs only this)
# HYDRA_TENANT_ID=appworld_agent       # tenant the agent stores/reads context under
# HYDRA_MAX_RESULTS=12                 # chunks injected into the prompt per task (API range 5..50)
# HYDRA_CHUNK_CHARS=1000               # max chars kept per recalled chunk
# HYDRA_READY_TIMEOUT=30               # seconds to wait for tenant readiness
